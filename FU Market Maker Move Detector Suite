// Inputs
periods = input.int(3, minval=1, title="Moving Average Period")
pt  = input.bool(false, title="Plot Triangles on Bars?")
pc  = input.bool(true,  title="Plot Swing Lines?")
pttb = input.bool(true, title="Plot Screen Edge Triangles?")
shb = input.bool(false, title="Highlight Bars on Cross?")
sbh = input.bool(true,  title="Background Highlight on Cross?")

// Smoothing
smaHigh = ta.sma(high, periods)
smaLow  = ta.sma(low, periods)

// Trend direction (no lag version)
var int trend = 0
trend := close > smaHigh ? 1 : close < smaLow ? -1 : trend

// Swing levels (persistent)
var float hi = na
var float lo = na

if trend == -1
    hi := smaHigh
    lo := na
else if trend == 1
    lo := smaLow
    hi := na

// Cross conditions (correct way)
crossUp   = ta.crossover(close, hi)
crossDown = ta.crossunder(close, lo)

// Bar highlight
barcolor(shb and (crossUp or crossDown) ? color.yellow : na)

// Background highlight
bgcolor(sbh and crossUp   ? color.new(color.green, 60) : na)
bgcolor(sbh and crossDown ? color.new(color.red, 60)   : na)

// Plot lines
plot(pc ? hi : na, title="Swing High", color=color.fuchsia, style=plot.style_linebr, linewidth=3)
plot(pc ? lo : na, title="Swing Low",  color=color.lime,    style=plot.style_linebr, linewidth=3)

// Triangles on bars
plotshape(pt and not na(hi), style=shape.triangledown, location=location.abovebar, color=color.fuchsia)
plotshape(pt and not na(lo), style=shape.triangleup,   location=location.belowbar, color=color.lime)

// Screen edge triangles
plotshape(pttb and not na(hi), style=shape.triangledown, location=location.top,    color=color.red)
plotshape(pttb and not na(lo), style=shape.triangleup,   location=location.bottom, color=color.lime)
